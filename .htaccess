# =====================================================
# .htaccess — LPA Laboratoire Privé d'Analyse
# Sécurité + HTTPS + Performance
# Compatible Apache 2.4+
# =====================================================

# ──────────────────────────────────────────────────
# 1. HTTPS — Redirection forcée HTTP → HTTPS
# ──────────────────────────────────────────────────
RewriteEngine On

# Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Forcer www (optionnel — décommenter si besoin)
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ──────────────────────────────────────────────────
# 2. EN-TÊTES DE SÉCURITÉ HTTP
# ──────────────────────────────────────────────────
<IfModule mod_headers.c>

    # Empêche le chargement dans des iframes (clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Empêche le MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Active la protection XSS du navigateur
    Header always set X-XSS-Protection "1; mode=block"

    # Contrôle les informations envoyées au referrer
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Limite l'accès aux fonctionnalités du navigateur
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # HTTP Strict Transport Security (HSTS) — force HTTPS 1 an
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https: data:; connect-src 'self' https://formspree.io https://api.anthropic.com; frame-ancestors 'self';"

    # Supprime les informations serveur
    Header unset Server
    Header unset X-Powered-By

</IfModule>

# ──────────────────────────────────────────────────
# 3. PERFORMANCES — Cache navigateur
# ──────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — pas de cache (toujours frais)
    ExpiresByType text/html                  "access plus 1 hour"

    # CSS et JavaScript
    ExpiresByType text/css                   "access plus 1 year"
    ExpiresByType application/javascript     "access plus 1 year"
    ExpiresByType text/javascript            "access plus 1 year"

    # Images
    ExpiresByType image/png                  "access plus 1 year"
    ExpiresByType image/jpg                  "access plus 1 year"
    ExpiresByType image/jpeg                 "access plus 1 year"
    ExpiresByType image/webp                 "access plus 1 year"
    ExpiresByType image/svg+xml              "access plus 1 year"
    ExpiresByType image/x-icon               "access plus 1 year"

    # Polices
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType font/woff                  "access plus 1 year"
    ExpiresByType font/ttf                   "access plus 1 year"
</IfModule>

# ──────────────────────────────────────────────────
# 4. COMPRESSION GZIP
# ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ──────────────────────────────────────────────────
# 5. BLOCAGE DE FICHIERS SENSIBLES
# ──────────────────────────────────────────────────
<FilesMatch "\.(env|log|sql|bak|sh|git|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protéger .htaccess lui-même
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

# ──────────────────────────────────────────────────
# 6. PAGE D'ERREUR PERSONNALISÉE
# ──────────────────────────────────────────────────
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html

# ──────────────────────────────────────────────────
# 7. OPTIONS DE SÉCURITÉ DIVERSES
# ──────────────────────────────────────────────────

# Désactiver la signature Apache
ServerSignature Off

# Désactiver l'affichage du répertoire
Options -Indexes

# Désactiver les SSI et CGI si non utilisés
Options -ExecCGI
Options -Includes
